{
  "expo": {
    "name": "Rainland",
    "slug": "atmosound",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.imethan.rainland",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSLocationWhenInUseUsageDescription": "用你的位置作為預設場景,呈現當地天氣與環境音。"
      }
    },
    "android": {
      "package": "com.imethan.rainland",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION", "FOREGROUND_SERVICE"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "用你的位置作為預設場景,呈現當地天氣與環境音。"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
